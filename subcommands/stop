#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

SERVICE="$1"

require_service "$SERVICE"

SERVICE_ROOT="$(service_root "$SERVICE")"
CONTAINER_NAME="$(service_container_name "$SERVICE")"
UI_CONTAINER_NAME="${CONTAINER_NAME}.ui"

dokku_log_info1 "Stopping ${PLUGIN_SERVICE} service $SERVICE"

# Stop and remove the main container
if $DOCKER_BIN inspect "$CONTAINER_NAME" &>/dev/null 2>&1; then
  if is_container_running "$CONTAINER_NAME"; then
    dokku_log_info2 "Stopping container $CONTAINER_NAME"
    $DOCKER_BIN stop "$CONTAINER_NAME"
  fi
  dokku_log_info2 "Removing container $CONTAINER_NAME"
  $DOCKER_BIN rm "$CONTAINER_NAME"
else
  dokku_log_warn "${PLUGIN_SERVICE} service '$SERVICE' is not running"
fi

# Stop and remove the UI container if it exists
if $DOCKER_BIN inspect "$UI_CONTAINER_NAME" &>/dev/null 2>&1; then
  if is_container_running "$UI_CONTAINER_NAME"; then
    dokku_log_info2 "Stopping UI container $UI_CONTAINER_NAME"
    $DOCKER_BIN stop "$UI_CONTAINER_NAME"
  fi
  dokku_log_info2 "Removing UI container $UI_CONTAINER_NAME"
  $DOCKER_BIN rm "$UI_CONTAINER_NAME"
fi

# Clear ID and IP files
rm -f "$SERVICE_ROOT/ID"
rm -f "$SERVICE_ROOT/IP"

dokku_log_info1 "${PLUGIN_SERVICE} service $SERVICE stopped"
