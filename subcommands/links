#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

SERVICE="$1"

require_service "$SERVICE"

SERVICE_ROOT="$(service_root "$SERVICE")"

if [[ ! -f "$SERVICE_ROOT/LINKS" ]] || [[ ! -s "$SERVICE_ROOT/LINKS" ]]; then
  dokku_log_info1 "No apps linked to ${PLUGIN_SERVICE} service $SERVICE"
  exit 0
fi

dokku_log_info1 "Apps linked to ${PLUGIN_SERVICE} service $SERVICE:"
while IFS= read -r app; do
  [[ -z "$app" ]] && continue
  echo "       $app"
done < "$SERVICE_ROOT/LINKS"
