#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

SERVICE="$1"
SUBCOMMAND="${2:-}"

require_service "$SERVICE"

CONTAINER_NAME="$(service_container_name "$SERVICE")"

if ! is_container_running "$CONTAINER_NAME"; then
  dokku_log_fail "${PLUGIN_SERVICE} service '$SERVICE' is not running. Start it first: dokku ${PLUGIN_COMMAND_PREFIX}:start $SERVICE"
fi

case "$SUBCOMMAND" in
  create)
    NS_NAME="${3:-}"
    if [[ -z "$NS_NAME" ]]; then
      dokku_log_fail "Usage: dokku ${PLUGIN_COMMAND_PREFIX}:namespace $SERVICE create <namespace>"
    fi
    # Validate namespace name
    if ! echo "$NS_NAME" | grep -qE '^[a-zA-Z0-9_-]+$'; then
      dokku_log_fail "Invalid namespace name '$NS_NAME'. Must contain only alphanumeric, underscore, and hyphen characters."
    fi
    dokku_log_info1 "Creating namespace '$NS_NAME' in ${PLUGIN_SERVICE} service $SERVICE"
    $DOCKER_BIN exec "$CONTAINER_NAME" \
      tctl --namespace "$NS_NAME" namespace register \
      2>&1 || {
        EXIT_CODE=$?
        # tctl exits 0 on success, non-zero on error; ignore "already exists" errors
        if $DOCKER_BIN exec "$CONTAINER_NAME" \
          tctl --namespace "$NS_NAME" namespace describe &>/dev/null 2>&1; then
          dokku_log_warn "Namespace '$NS_NAME' already exists"
          exit 0
        fi
        exit $EXIT_CODE
      }
    dokku_log_info1 "Namespace '$NS_NAME' created"
    dokku_log_info2 "To link an app with this namespace: dokku ${PLUGIN_COMMAND_PREFIX}:link $SERVICE <app> --namespace $NS_NAME"
    ;;

  list)
    dokku_log_info1 "Listing namespaces in ${PLUGIN_SERVICE} service $SERVICE"
    $DOCKER_BIN exec "$CONTAINER_NAME" tctl namespace list
    ;;

  *)
    echo "Usage:"
    echo "  dokku ${PLUGIN_COMMAND_PREFIX}:namespace $SERVICE create <namespace>  -- create a namespace"
    echo "  dokku ${PLUGIN_COMMAND_PREFIX}:namespace $SERVICE list                -- list namespaces"
    exit 1
    ;;
esac
