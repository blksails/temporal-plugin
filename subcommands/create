#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

SERVICE="$1"

verify_service_name "$SERVICE"

SERVICE_ROOT="$(service_root "$SERVICE")"

if service_exists "$SERVICE"; then
  dokku_log_fail "${PLUGIN_SERVICE} service '$SERVICE' already exists"
fi

dokku_log_info1 "Creating ${PLUGIN_SERVICE} service $SERVICE"

mkdir -p "$SERVICE_ROOT"
chmod 700 "$SERVICE_ROOT"

# Write default configuration files
echo "$PLUGIN_IMAGE" > "$SERVICE_ROOT/IMAGE"
echo "$PLUGIN_IMAGE_VERSION" > "$SERVICE_ROOT/IMAGE_VERSION"
echo "7233" > "$SERVICE_ROOT/PORT"
echo "8233" > "$SERVICE_ROOT/UI_PORT"
touch "$SERVICE_ROOT/LINKS"

# Set non-credential file permissions
chmod 640 "$SERVICE_ROOT/IMAGE"
chmod 640 "$SERVICE_ROOT/IMAGE_VERSION"
chmod 640 "$SERVICE_ROOT/PORT"
chmod 640 "$SERVICE_ROOT/UI_PORT"
chmod 640 "$SERVICE_ROOT/LINKS"

# Copy default dynamicconfig directory to service directory
PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
if [[ -d "$PLUGIN_DIR/dynamicconfig" ]]; then
  cp -r "$PLUGIN_DIR/dynamicconfig" "$SERVICE_ROOT/dynamicconfig"
fi

# Set secure permissions on the service directory (700: owner only)
chmod 700 "$SERVICE_ROOT"

dokku_log_info1 "${PLUGIN_SERVICE} service $SERVICE created"
dokku_log_info2 "To configure the service, run:"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_HOST <host>"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_PORT <port>"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_USER <user>"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_PWD <password>"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_DB <database>"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE POSTGRES_TLS true"
dokku_log_info2 ""
dokku_log_info2 "Or use a DATABASE_URL:"
dokku_log_info2 "  dokku ${PLUGIN_COMMAND_PREFIX}:set $SERVICE DATABASE_URL postgres://user:pwd@host:port/db"
dokku_log_info2 ""
dokku_log_info2 "Then start with: dokku ${PLUGIN_COMMAND_PREFIX}:start $SERVICE"
