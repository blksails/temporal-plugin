#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

if [[ ! -d "$PLUGIN_BASE_PATH" ]]; then
  echo "There are no ${PLUGIN_SERVICE} services"
  exit 0
fi

# Collect service directories
SERVICES=()
while IFS= read -r -d '' dir; do
  service="$(basename "$dir")"
  SERVICES+=("$service")
done < <(find "$PLUGIN_BASE_PATH" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null | sort -z)

if [[ ${#SERVICES[@]} -eq 0 ]]; then
  echo "There are no ${PLUGIN_SERVICE} services"
  exit 0
fi

# Print header
printf "%-20s  %-10s  %-20s\n" "NAME" "STATUS" "VERSION"
printf "%-20s  %-10s  %-20s\n" "----" "------" "-------"

for service in "${SERVICES[@]}"; do
  SERVICE_ROOT="$(service_root "$service")"
  CONTAINER_NAME="$(service_container_name "$service")"
  IMAGE_VERSION="$(cat "$SERVICE_ROOT/IMAGE_VERSION" 2>/dev/null || echo "$PLUGIN_IMAGE_VERSION")"

  if is_container_running "$CONTAINER_NAME"; then
    STATUS="running"
  else
    STATUS="stopped"
  fi

  printf "%-20s  %-10s  %-20s\n" "$service" "$STATUS" "$IMAGE_VERSION"
done
