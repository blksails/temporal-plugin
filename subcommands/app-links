#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../common-functions"

APP="$1"

if [[ -z "$APP" ]]; then
  dokku_log_fail "Please specify an app name"
fi

# Check the app exists
if ! dokku apps:exists "$APP" &>/dev/null 2>&1; then
  dokku_log_fail "App '$APP' does not exist"
fi

FOUND=false

if [[ -d "$PLUGIN_BASE_PATH" ]]; then
  for service_dir in "$PLUGIN_BASE_PATH"/*/; do
    [[ -d "$service_dir" ]] || continue
    SERVICE="$(basename "$service_dir")"
    LINKS_FILE="${service_dir}LINKS"
    if [[ -f "$LINKS_FILE" ]] && grep -qxF "$APP" "$LINKS_FILE"; then
      echo "$SERVICE"
      FOUND=true
    fi
  done
fi

if [[ "$FOUND" == "false" ]]; then
  dokku_log_info1 "App '$APP' is not linked to any ${PLUGIN_SERVICE} service"
fi
