#!/usr/bin/env bash
# Trigger: post-app-clone-setup
# When a Dokku app is cloned, replicate Temporal link relationships to the new app.
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common-functions"

OLD_APP="$1"
NEW_APP="$2"

[[ -z "$OLD_APP" || -z "$NEW_APP" ]] && exit 0

[[ -d "$PLUGIN_BASE_PATH" ]] || exit 0

for service_dir in "$PLUGIN_BASE_PATH"/*/; do
  [[ -d "$service_dir" ]] || continue
  SERVICE="$(basename "$service_dir")"
  LINKS_FILE="${service_dir}LINKS"

  if [[ -f "$LINKS_FILE" ]] && grep -qxF "$OLD_APP" "$LINKS_FILE"; then
    dokku_log_info1 "Linking cloned app '$NEW_APP' to ${PLUGIN_SERVICE} service '$SERVICE'..."
    dokku "${PLUGIN_COMMAND_PREFIX}:link" "$SERVICE" "$NEW_APP" --no-restart || \
      dokku_log_warn "Failed to link '$NEW_APP' to ${PLUGIN_SERVICE} service '$SERVICE'"
  fi
done
