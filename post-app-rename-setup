#!/usr/bin/env bash
# Trigger: post-app-rename-setup
# When a Dokku app is renamed, update the LINKS file in all linked Temporal services.
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/config"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common-functions"

OLD_APP="$1"
NEW_APP="$2"

[[ -z "$OLD_APP" || -z "$NEW_APP" ]] && exit 0

[[ -d "$PLUGIN_BASE_PATH" ]] || exit 0

for service_dir in "$PLUGIN_BASE_PATH"/*/; do
  [[ -d "$service_dir" ]] || continue
  SERVICE="$(basename "$service_dir")"
  LINKS_FILE="${service_dir}LINKS"

  if [[ -f "$LINKS_FILE" ]] && grep -qxF "$OLD_APP" "$LINKS_FILE"; then
    dokku_log_info1 "Updating ${PLUGIN_SERVICE} service '$SERVICE' links: '$OLD_APP' -> '$NEW_APP'"

    # Replace old app name with new app name in LINKS file
    LINKS_TMP="$(mktemp)"
    sed "s/^${OLD_APP}$/${NEW_APP}/" "$LINKS_FILE" > "$LINKS_TMP"
    mv "$LINKS_TMP" "$LINKS_FILE"
  fi
done
